# Normalize repository text files to LF.
* text=auto eol=lf

# Source, configuration, and documentation formats expected in review diffs.
*.rs text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.txt text eol=lf

# Generated governance stays committed for bootstrap without dominating stats.
AGENTS.md linguist-generated=true
.codex/skills/** linguist-generated=true
governance/core/** linguist-generated=true

# Binary and archive artifacts.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.tgz binary
*.gz binary
